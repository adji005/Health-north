{% extends 'base.html.twig' %}

{% block title %}Dr. {{ medecin.nom }} - Health North{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm p-4 text-center">
                <i class="bi bi-person-circle fs-1 text-secondary"></i>
                <h4 class="mt-2">Dr. {{ medecin.prenom }} {{ medecin.nom }}</h4>
                <p class="text-muted">{{ medecin.specialite }}</p>
                {% if medecin.conventionneSecu %}
                    <span class="badge bg-success">Conventionné Sécurité Sociale</span>
                {% endif %}
                <hr>
                <p><i class="bi bi-geo-alt"></i> {{ medecin.adresse }}</p>
                <p><i class="bi bi-telephone"></i> {{ medecin.telephone }}</p>
                <p><i class="bi bi-credit-card"></i> Secteur {{ medecin.secteur }}</p>
            </div>
        </div>

        <div class="col-md-8">
            {% if medecin.description %}
            <div class="card shadow-sm p-4 mb-3">
                <h5>À propos</h5>
                <p>{{ medecin.description }}</p>
            </div>
            {% endif %}

            <div class="card shadow-sm p-4 mb-3">
                <h5>Disponibilités</h5>
                {% if medecin.disponibilites|length == 0 %}
                    <p class="text-muted">Aucune disponibilité renseignée.</p>
                {% else %}
                    <p class="text-muted small">Cliquez sur un créneau pour pré-remplir la date</p>
                    {% for dispo in medecin.disponibilites %}
    <button type="button" class="btn btn-outline-primary btn-sm me-1 mb-1 dispo-btn"
            data-datetime="{{ dispo.date|date('Y-m-d') }}T{{ dispo.heureDebut|date('H:i') }}">
        {{ dispo.date|date('d/m/Y') }} : {{ dispo.heureDebut|date('H:i') }} - {{ dispo.heureFin|date('H:i') }}
    </button>
{% endfor %}
                {% endif %}
            </div>

            {% if app.user and is_granted('ROLE_PATIENT') %}
            <div class="card shadow-sm p-4">
                <h5>Prendre rendez-vous</h5>
                <form method="post" action="{{ path('patient_rdv_prendre') }}">
                    <input type="hidden" name="medecin_id" value="{{ medecin.id }}">
                    
                    <div class="mb-3">
                        <label class="form-label">Date et heure</label>
                        <input type="datetime-local" name="dateHeure" id="dateHeure" class="form-control" required>
                        <small class="text-muted">Cliquez sur une disponibilité ci-dessus pour pré-remplir</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Motif (optionnel)</label>
                        <textarea name="motif" class="form-control" rows="2"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-calendar-check"></i> Confirmer le rendez-vous
                    </button>
                </form>
            </div>
            {% elseif not app.user %}
            <div class="alert alert-info">
                <a href="{{ path('app_login') }}">Connectez-vous</a> pour prendre rendez-vous.
            </div>
            {% endif %}
        </div>
    </div>

    <a href="{{ path('search') }}" class="btn btn-secondary mt-3">
        <i class="bi bi-arrow-left"></i> Retour à la recherche
    </a>
</div>

<script>
document.querySelectorAll('.dispo-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const datetime = this.dataset.datetime;
        document.getElementById('dateHeure').value = datetime;
        
        document.querySelectorAll('.dispo-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
    });
});
</script>
{% endblock %}