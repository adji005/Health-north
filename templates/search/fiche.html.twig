{% extends 'base.html.twig' %}

{% block title %}Dr. {{ medecin.nom }} - Health North{% endblock %}

{% block body %}

<style>
    body {
        font-family: 'Inter';
    }

    .btn {
        font-size: 1rem;
        border: 1.5px solid #f8f8f8;
        border-radius: 0.5rem;
        box-shadow: 2.5px 3px 0 #082833;
        outline: none;
        transition: ease 0.25s;
        font-weight: 600;
        white-space: nowrap;
        padding: 0.875rem 2rem;
    }

    .btn:hover {
        box-shadow: 5.5px 7px 0 #082833;
        transform: translateY(-2px);
    }

    .button {
        font-size: 1rem;
        border: 1.5px solid #082833;
        border-radius: 0.5rem;
        outline: none;
        transition: ease 0.25s;
        font-weight: 600;
        white-space: nowrap;
        padding: 5px;
        background-color: #fff;
        color: #082833;
    }

    .button:hover {
        box-shadow: 2px 5px 0 #082833;
        transform: translateY(-2px);
    }

    .button.active {
        background-color: #082833;
        color: white;
    }
</style>

<div class="mb-5 pb-5"></div>

<!--fiche medecin -->
<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm p-4 text-center" style="border-color: #082833;">
                <i class="bi bi-person-circle fs-1 text-secondary"></i>
                <h4 class="mt-2">Dr. {{ medecin.prenom }} {{ medecin.nom }}</h4>
                <p class="text-muted">{{ medecin.specialite }}</p>
                {% if medecin.conventionneSecu %}
                <span class="badge" style="background-color: #082833;">Conventionné Sécurité Sociale</span>
                {% endif %}
                <hr>
                <p><i class="bi bi-geo-alt"></i> {{ medecin.adresse }}</p>
                <p><i class="bi bi-telephone"></i> {{ medecin.telephone }}</p>
                <p><i class="bi bi-credit-card"></i> Secteur {{ medecin.secteur }}</p>
            </div>
        </div>

        <!-- affiche les disponiblte du doc -->
        <div class="col-md-8">
            <div class="card shadow-sm p-4 mb-3">
                <h5>Disponibilités</h5>
                {% if disponibilites|length == 0 %}
                <p class="text-muted">Aucune disponibilité</p>
                {% else %}
                <p class="text-muted small">Choisissez un créneau</p>
                {% for dispo in disponibilites %}
                <button type="button" class="button btn-sm me-1 mb-1 dispo-btn"
                    data-datetime="{{ dispo.date|date('Y-m-d') }}T{{ dispo.heureDebut|date('H:i') }}">
                    {{ dispo.date|date('d/m/Y') }} : {{ dispo.heureDebut|date('H:i') }} - {{ dispo.heureFin|date('H:i') }}
                </button>
                {% endfor %}
                {% endif %}
            </div>

            <!-- Possibilité de prendre rendez-vous que pour les patients -->

            {% if app.user and is_granted('ROLE_PATIENT') %}
            <div class="card shadow-sm p-4">
                <h5>Prendre rendez-vous</h5>
                <form method="post" action="{{ path('patient_rdv_prendre') }}">
                    <input type="hidden" name="medecin_id" value="{{ medecin.id }}">
                    <div class="mb-3">
                        <label class="form-label">Date et heure</label>
                        <input type="datetime-local" name="dateHeure" id="dateHeure" class="form-control" required>
                        <small class="text-muted">Cliquez sur une disponibilité ci-dessus pour pré-remplir</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Motif (optionnel)</label>
                        <textarea name="motif" class="form-control" rows="2"></textarea>
                    </div>
                    <button type="submit" class="btn w-100">
                        <i class="bi bi-calendar-check"></i> Confirmer le rendez-vous
                    </button>
                </form>
            </div>

            <!--si n'est pas connecte, lien vers la page de login-->
            {% elseif not app.user %}
            <a href="{{ path('app_login') }}" style="color: #082833;">Connectez-vous</a> pour prendre rendez-vous.
            {% endif %}
        </div>
    </div>

    <a href="{{ path('search') }}" class="btn mt-3">
        <i class="bi bi-arrow-left"></i> Retour à la recherche
    </a>
</div>

<div class="mb-5 pb-5"></div>
<div class="mb-5 pb-5"></div>

<!--pre rempli le creneau quand on clique sur une disponibilité-->
<script>
    document.querySelectorAll('.dispo-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            const datetime = this.dataset.datetime;
            document.getElementById('dateHeure').value = datetime;

            document.querySelectorAll('.dispo-btn').forEach(b => b.classList.remove('active'));
            
            this.classList.add('active');
        });
    });
</script>
{% endblock %}