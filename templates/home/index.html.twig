{% extends 'base.html.twig' %}

{% block title %}Health North - Prenez rendez-vous en ligne{% endblock %}

{% block body %}
<div class="bg-primary text-white py-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">Health North</h1>
        <p class="lead">Trouvez un médecin et prenez rendez-vous en ligne</p>
        <div class="row justify-content-center mt-4">
            <div class="col-md-6">
                <form action="{{ path('search') }}" method="GET" class="d-flex gap-2">
                    <input type="text" name="ville" class="form-control form-control-lg" placeholder="Ville...">
                    <input type="text" name="specialite" class="form-control form-control-lg" placeholder="Spécialité...">
                    <button type="submit" class="btn btn-light btn-lg">Rechercher</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="container mt-5">
    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <i class="bi bi-search fs-1 text-primary mb-3"></i>
                <h4>Trouvez un médecin</h4>
                <p class="text-muted">Recherchez par spécialité, ville ou disponibilité</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <i class="bi bi-calendar-check fs-1 text-primary mb-3"></i>
                <h4>Prenez rendez-vous</h4>
                <p class="text-muted">Réservez en ligne 24h/24, 7j/7</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <i class="bi bi-file-medical fs-1 text-primary mb-3"></i>
                <h4>Gérez votre dossier</h4>
                <p class="text-muted">Accédez à vos ordonnances et documents médicaux</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}