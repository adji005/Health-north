<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Health North{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --hn-blue: #154b92;
            --hn-light: #f8f9fa;
        }
        .navbar-brand { 
            font-weight: 700;
             color: var(--hn-blue) !important; 
        }
        .btn-primary { 
            background-color: var(--hn-blue);
            border-color: var(--hn-blue); 
        }
        .sidebar { 
            min-height: 100vh; 
            background: var(--hn-light); 
            border-right: 1px solid #dee2e6; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
    <div class="container">
        {% if app.user %}
    <span class="navbar-brand">
        <i class="bi bi-heart-pulse-fill text-primary"></i> Health North
    </span>
{% else %}
    <a class="navbar-brand" href="{{ path('app_home') }}">
        <i class="bi bi-heart-pulse-fill text-primary"></i> Health North
    </a>
{% endif %}
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                {% if app.user %}
                    {% if is_granted('ROLE_PATIENT') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('patient_dashboard') }}">Mon espace</a>
                        </li>
                    {% endif %}
                    {% if is_granted('ROLE_DOCTOR') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('doctor_dashboard') }}">Mon planning</a>
                        </li>
                    {% endif %}
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('admin_dashboard') }}">Admin</a>
                        </li>
                    {% endif %}
                    <li class="nav-item">
                        <a class="nav-link text-danger" href="{{ path('app_logout') }}">Déconnexion</a>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-primary text-white px-3" href="{{ path('app_register') }}">S'inscrire</a>
                    </li>
                    <li class="nav-item">
                                <a href="{{ path('app_register_doctor') }}" class="btn btn-outline-primary btn-lg">Vous êtes médecin ?</a>

                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-4">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
</div>

{% block body %}{% endblock %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>