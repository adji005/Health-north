<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Health North{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            padding-top: 80px;
            font-family: 'Inter', sans-serif;
        }

        .navbar {
            background-color: #082833 !important;
        }

        .navbar-brand {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            color: #fff !important;
            font-size: 1.5rem;
        }

        .nav-link {
            color: #ffffff !important;
            font-family: 'Inter', sans-serif;
            font-weight: 500;
            font-size: 15px;
            padding: 1px 10px !important;
            text-decoration: none;
            border-bottom: 2px solid transparent;
            transition: all 0.3s ease;
        }

        .nav-link:hover {
            border-bottom-color: #fff;
        }

        .nav-link.active {
            font-weight: 600;
            border-bottom-color: #fff;
        }

        .btn-primary {
            background-color: #154b92;
            border-color: #154b92;
        }

        @media (max-width: 768px) {
            body {
                padding-top: 70px;
            }
        }
    </style>
</head>

<body>
 
    <nav class="navbar navbar-expand-lg fixed-top py-3">
        <div class="container-fluid">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                Health North
            </a>

            <button class="navbar-toggler bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    {% if app.user %}
                        {% if is_granted('ROLE_PATIENT') %}
                        <li class="nav-item">
                            <a class="nav-link {{ app.request.get('_route') == 'patient_dashboard' ? 'active' : '' }}"
                                href="{{ path('patient_dashboard') }}">Mon espace</a>
                        </li>
                        {% endif %}
                        {% if is_granted('ROLE_DOCTOR') %}
                        <li class="nav-item">
                            <a class="nav-link {{ app.request.get('_route') == 'doctor_dashboard' ? 'active' : '' }}"
                                href="{{ path('doctor_dashboard') }}">Mon planning</a>
                        </li>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link {{ app.request.get('_route') == 'admin_dashboard' ? 'active' : '' }}"
                                href="{{ path('admin_dashboard') }}">Admin</a>
                        </li>
                        {% endif %}
                        <li class="nav-item">
                            <a class="nav-link text-danger" href="{{ path('app_logout') }}">Déconnexion</a>
                        </li>
                    {% else %}
                        <li class="nav-item">
                            <a class="nav-link {{ app.request.get('_route') == 'app_login' ? 'active' : '' }}"
                                href="{{ path('app_login') }}">Connexion</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {{ app.request.get('_route') == 'app_register' ? 'active' : '' }}"
                                href="{{ path('app_register') }}">S'inscrire</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {{ app.request.get('_route') == 'app_register_doctor' ? 'active' : '' }}"
                                href="{{ path('app_register_doctor') }}">Vous êtes médecin ?</a>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    <div class="toast-container position-fixed end-0 p-3" style="z-index: 9999; top: 100px;">
        {% for message in app.flashes('success') %}
        <div class="toast show align-items-center text-bg-success border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
        {% endfor %}
        
        {% for message in app.flashes('error') %}
        <div class="toast show align-items-center text-bg-danger border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-exclamation-circle-fill me-2"></i> {{ message }}
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
        {% endfor %}
    </div>

    <script>
    // Auto-hide toasts après 4 secondes
    document.addEventListener('DOMContentLoaded', function() {
        setTimeout(() => {
            document.querySelectorAll('.toast').forEach(toast => {
                toast.classList.remove('show');
            });
        }, 4000);
    });
    </script>

    {% block body %}{% endblock %}



S
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>