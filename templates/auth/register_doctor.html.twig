{% extends 'base.html.twig' %}

{% block title %}Inscription Médecin - Health North{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-center mb-4">
                        <i class="bi bi-heart-pulse-fill text-primary"></i> Health North
                    </h2>
                    <h5 class="text-center text-muted mb-4">Demande d'inscription médecin</h5>

                    <form id="registerDoctorForm">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Nom</label>
                                <input type="text" name="nom" class="form-control" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Prénom</label>
                                <input type="text" name="prenom" class="form-control" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" name="email" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mot de passe</label>
                            <input type="password" name="password" class="form-control" required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
    <label class="form-label">Spécialité</label>
    <input type="text" name="specialite" class="form-control" list="specialites" required>
    <datalist id="specialites">
        <option value="Médecine générale">
        <option value="Cardiologie">
        <option value="Dermatologie">
        <option value="Ophtalmologie">
        <option value="Pédiatrie">
        <option value="Gynécologie">
        <option value="Psychiatrie">
        <option value="Radiologie">
        <option value="Anesthésie">
        <option value="Chirurgie">
    </datalist>
</div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Numéro RPPS</label>
                                <input type="text" name="numeroRPPS" class="form-control" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Téléphone</label>
                            <input type="tel" name="telephone" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Adresse du cabinet</label>
                            <input type="text" name="adresse" class="form-control" required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Ville</label>
                                <input type="text" name="ville" class="form-control" required>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Code postal</label>
                                <input type="text" name="codePostal" class="form-control" required>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Secteur</label>
                                <select name="secteur" class="form-select" required>
                                    <option value="1">Secteur 1</option>
                                    <option value="2">Secteur 2</option>
                                    <option value="3">Secteur 3</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="form-check">
                                <input type="checkbox" name="conventionneSecu" class="form-check-input" id="conventionneSecu">
                                <label class="form-check-label" for="conventionneSecu">Conventionné Sécurité Sociale</label>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Envoyer ma demande</button>
                    </form>

                    <hr>
                    <div class="text-center">
                        <a href="{{ path('app_login') }}">Déjà un compte ? Se connecter</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('registerDoctorForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    const data = Object.fromEntries(formData.entries());
    data.conventionneSecu = document.getElementById('conventionneSecu').checked;

    const response = await fetch('{{ path("api_register_doctor") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    });

    const result = await response.json();

    if (response.ok) {
        alert('Demande envoyée ! Vous serez contacté après validation.');
        window.location.href = '{{ path("app_login") }}';
    } else {
        alert(result.error);
    }
});
</script>

<script>
const adresseInput = document.querySelector('input[name="adresse"]');
const suggestionsDiv = document.createElement('div');
suggestionsDiv.className = 'list-group position-absolute';
suggestionsDiv.style.zIndex = '1000';
suggestionsDiv.style.maxWidth = adresseInput.offsetWidth + 'px';
adresseInput.parentElement.style.position = 'relative';
adresseInput.parentElement.appendChild(suggestionsDiv);

adresseInput.addEventListener('input', async function() {
    const query = this.value;
    if (query.length < 3) {
        suggestionsDiv.innerHTML = '';
        return;
    }

    const response = await fetch(`https://api-adresse.data.gouv.fr/search/?q=${encodeURIComponent(query)}&limit=5`);
    const data = await response.json();

    suggestionsDiv.innerHTML = '';
    data.features.forEach(feature => {
        const item = document.createElement('a');
        item.className = 'list-group-item list-group-item-action';
        item.textContent = feature.properties.label;
        item.style.cursor = 'pointer';
        item.addEventListener('click', function() {
            adresseInput.value = feature.properties.label;
            suggestionsDiv.innerHTML = '';
        });
        suggestionsDiv.appendChild(item);
    });
});

document.addEventListener('click', function(e) {
    if (e.target !== adresseInput) {
        suggestionsDiv.innerHTML = '';
    }
});
</script>
{% endblock %}