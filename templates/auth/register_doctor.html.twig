{% extends 'base.html.twig' %}

{% block title %}Inscription Médecin - Health North{% endblock %}

{% block body %}


<style>
    .form-control {
        font-size: 1rem;
        border: 1.5px solid #f8f8f8;
        border-radius: 0.5rem;
        box-shadow: 2.5px 3px 0 #082833;
        outline: none;
        transition: ease 0.25s;
        padding: 0.875rem;
    }

    .form-control:focus {
        box-shadow: 5.5px 7px 0 #082833;
        transform: translateY(-2px);
        border-color: #f8f8f8;
    }

    .form-label {
        font-weight: 600;
        color: #072935;
        margin-bottom: 0.5rem;
    }

    .btn {
        font-size: 1rem;
        border: 1.5px solid #f8f8f8;
        border-radius: 0.5rem;
        box-shadow: 2.5px 3px 0 #082833;
        outline: none;
        transition: ease 0.25s;
        font-weight: 600;
        padding: 0.875rem 2rem;
        background-color: #082833;
        border-color: #a9bfda;
      
    }

    .btn:hover {
        box-shadow: 5.5px 7px 0 #082833;
        transform: translateY(-2px);
        background-color: #082833;
        border: 1.5px solid #f8f8f8;


    }
</style>

<div class="mb-5 pb-5"></div>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm" style="border-color: #072935; border-width:3px;">
                <div class="card-body p-4">
                    <h2 class="text-center mb-4" style="font-weight:bolder; color:#082833; font-family:'Poppins'">Health North
                    </h2>
                    <h5 class="text-center text-muted mb-4" style="font-size:14px">Demande d'inscription médecin</h5>

                    <form id="registerDoctorForm">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Nom</label>
                                <input type="text" name="nom" class="form-control" placeholder="Nom..." required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Prénom</label>
                                <input type="text" name="prenom" class="form-control" placeholder="Prénom..." required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" name="email" class="form-control" placeholder="Email..."required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mot de passe</label>
                            <input type="password" name="password" class="form-control" placeholder="Mot de passe..."required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                            <!--suggestion-->
    <label class="form-label">Spécialité</label>
    <input type="text" name="specialite" class="form-control" list="specialites" placeholder="Spécialité..."required>
    <datalist id="specialites">
        <option value="Médecine générale">
        <option value="Cardiologie">
        <option value="Dermatologie">
        <option value="Ophtalmologie">
        <option value="Pédiatrie">
        <option value="Gynécologie">
        <option value="Psychiatrie">
        <option value="Radiologie">
        <option value="Anesthésie">
        <option value="Chirurgie">
    </datalist>
</div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Numéro RPPS</label>
                                <input type="text" name="numeroRPPS" class="form-control" placeholder="RPPS..." required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Téléphone</label>
                            <input type="tel" name="telephone" class="form-control" placeholder="Numéro..." required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Adresse du cabinet</label>
                            <input type="text" name="adresse" class="form-control" placeholder="Adresse..." required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Ville</label>
                                <input type="text" name="ville" class="form-control" placeholder="Ville..." required>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Code postal</label>
                                <input type="text" name="codePostal" class="form-control" placeholder="Code Postal..." required>
                            </div>
                            <div class="col-md-3 mb-3" style="border-color:#072935 !important;">
                                <label class="form-label">Secteur</label>
                                <select name="secteur" class="form-select" required>
                                    <option value="" disabled selected>Sélectionnez un secteur</option>
                                    <option value="1">Secteur 1</option>
                                    <option value="2">Secteur 2</option>
                                    <option value="3">Secteur 3</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="form-check">
                                <input type="checkbox" name="conventionneSecu" class="form-check-input" id="conventionneSecu">
                                <label class="form-check-label" for="conventionneSecu">Conventionné Sécurité Sociale</label>
                            </div>
                        </div>
                        <button type="submit" class=" btn text-white" style="padding: 20px 255px">Envoyer ma demande</button>
                    </form>

                    <hr>
                    <div class="text-center">
                        <a href="{{ path('app_login') }}" style="color: #072935; text-decoration: none;">Déjà un compte ? Se connecter</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mb-5 pb-5"></div>
<div class="mb-5 pb-5"></div>

<script>
document.getElementById('registerDoctorForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    const data = Object.fromEntries(formData.entries());
    data.conventionneSecu = document.getElementById('conventionneSecu').checked;

<!--regex pour mdp genre condition-->

    const passwordRegex = /^(?=.*[A-Z])(?=.*\d).{8,}$/;
    if (!passwordRegex.test(data.password)) {
        alert('Le mot de passe doit contenir au moins 8 caractères, 1 majuscule et 1 chiffre');
        return;
    }

    const response = await fetch('{{ path("api_register_doctor") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    });

    const result = await response.json();

    if (response.ok) {
        alert('Demande envoyée ! Vous serez contacté après validation.');
        window.location.href = '{{ path("app_home") }}';
    } else {
        alert(result.error);
    }
});
</script>

<script>
const adresseInput = document.querySelector('input[name="adresse"]');
const suggestionsDiv = document.createElement('div');
suggestionsDiv.className = 'list-group position-absolute';
suggestionsDiv.style.zIndex = '1000';
suggestionsDiv.style.maxWidth = adresseInput.offsetWidth + 'px';
adresseInput.parentElement.style.position = 'relative';
adresseInput.parentElement.appendChild(suggestionsDiv);

adresseInput.addEventListener('input', async function() {
    const query = this.value;
    if (query.length < 3) {
        suggestionsDiv.innerHTML = '';
        return;
    }

<!--api du gouv-->
    const response = await fetch(`https://api-adresse.data.gouv.fr/search/?q=${encodeURIComponent(query)}&limit=5`);
    const data = await response.json();

    suggestionsDiv.innerHTML = '';
    data.features.forEach(feature => {
        const item = document.createElement('a');
        item.className = 'list-group-item list-group-item-action';
        item.textContent = feature.properties.label;
        item.style.cursor = 'pointer';
        item.addEventListener('click', function() {
            adresseInput.value = feature.properties.label;
            suggestionsDiv.innerHTML = '';
        });
        suggestionsDiv.appendChild(item);
    });
});

document.addEventListener('click', function(e) {
    if (e.target !== adresseInput) {
        suggestionsDiv.innerHTML = '';
    }
});
</script>
{% endblock %}