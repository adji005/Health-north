{% extends 'base.html.twig' %}

{% block title %}Connexion - Health North{% endblock %}

{% block body %}

<style>
    .form-control {
        font-size: 1rem;
        border: 1.5px solid #f8f8f8;
        border-radius: 0.5rem;
        box-shadow: 2.5px 3px 0 #082833;
        outline: none;
        transition: ease 0.25s;
        padding: 0.875rem;
    }

    .form-control:focus {
        box-shadow: 5.5px 7px 0 #082833;
        transform: translateY(-2px);
        border-color: #f8f8f8;
    }

    .form-label {
        font-weight: 600;
        color: #072935;
        margin-bottom: 0.5rem;
    }

    .btn {
        font-size: 1rem;
        border: 1.5px solid #f8f8f8;
        border-radius: 0.5rem;
        box-shadow: 2.5px 3px 0 #082833;
        outline: none;
        transition: ease 0.25s;
        font-weight: 600;
        padding: 0.875rem 2rem;
        background-color: #082833;
        border-color: #a9bfda;
    }

    .btn:hover {
        box-shadow: 5.5px 7px 0 #082833;
        transform: translateY(-2px);
        background-color: #082833;
        border: 1.5px solid #f8f8f8;


    }
</style>

<div class="mb-5 pb-5"></div>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm" style="border-color: #072935; border-width:3px; ">
                <div class="card-body p-4">
                    <h2 class="text-center mb-4" style="font-family: 'Poppins'; color: #072935; font-weight: bolder;">Health North</h2>
                    <h5 class="text-center text-muted mb-4" style="font-size: 14px;">Connexion</h5>

                    {% if error %}
                        <div class="alert alert-danger">{{ error.messageKey }}</div>
                    {% endif %}

                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" name="email" class="form-control"  placeholder="Email..."
                                   value="{{ last_username }}" required autofocus>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mot de passe</label>
                            <input type="password" name="password" class="form-control"placeholder="Password..." required>
                        </div>
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                        <button type="submit" class="btn w-100" style="color:#fff">Se connecter</button>
                    </form>

                    <hr>
                    <div class="text-center">
                        <a href="{{ path('app_register') }}" style="color: #072935; text-decoration: none;">Pas encore de compte ? S'inscrire</a>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mb-5 pb-5"></div>
<div class="mb-5 pb-5"></div>

{% endblock %}