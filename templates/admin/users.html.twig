{% extends 'base.html.twig' %}

{% block title %}Utilisateurs - Health North{% endblock %}

{% block body %}
<div class="container mt-4">
    <h2><i class="bi bi-people text-primary"></i> Gestion des utilisateurs</h2>
    <hr>

    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Email</th>
                <th>Rôle</th>
                <th>Statut</th>
                <th>Créé le</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
            <tr>
                <td>{{ user.email }}</td>
                <td>
                    {% if 'ROLE_ADMIN' in user.roles %}
                        <span class="badge bg-danger">Admin</span>
                    {% elseif 'ROLE_DOCTOR' in user.roles %}
                        <span class="badge bg-success">Médecin</span>
                    {% else %}
                        <span class="badge bg-primary">Patient</span>
                    {% endif %}
                </td>
                <td>
                    {% if user.active %}
                        <span class="badge bg-success">Actif</span>
                    {% else %}
                        <span class="badge bg-secondary">Inactif</span>
                    {% endif %}
                </td>
                <td>{{ user.createdAt ? user.createdAt|date('d/m/Y') : '-' }}</td>
                <td>
                    <form method="post" action="{{ path('admin_user_toggle', {id: user.id}) }}" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                        <button type="submit" class="btn btn-sm {% if user.active %}btn-warning{% else %}btn-success{% endif %}">
                            {% if user.active %}
                                <i class="bi bi-pause-circle"></i> Désactiver
                            {% else %}
                                <i class="bi bi-play-circle"></i> Activer
                            {% endif %}
                        </button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary mt-2">
        <i class="bi bi-arrow-left"></i> Retour au dashboard
    </a>
</div>
{% endblock %}