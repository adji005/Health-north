{% extends 'base.html.twig' %}

{% block title %}Utilisateurs - Health North{% endblock %}

{% block body %}

<style>
    
        .button {
        font-size: 1rem;
        border: 1.5px solid #ffffff ;
        background-color: white;
        border-radius: 0.5rem;
        box-shadow: 2.5px 3px 0 #082833;
        outline: none;
        transition: ease 0.25s;
        font-weight: 600;
        white-space: nowrap;
        padding: 3px 6px;
    }

     .button:hover {
        box-shadow: 5.5px 7px 0 #082833;
        transform: translateY(-2px);
     }
</style>

<!-- desactivation et activation des membres-->

<div class="container mt-4">
    <h2> Gestion des utilisateurs</h2>
    <hr>

    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Email</th>
                <th>Rôle</th>
                <th>Statut</th>
                <th>Créé le</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
            <tr>
                <td>{{ user.email }}</td>
                <td>
                    {% if 'ROLE_ADMIN' in user.roles %}
                        <span class="badge" style="background-color: #b0c3ff;">Admin</span>
                    {% elseif 'ROLE_DOCTOR' in user.roles %}
                        <span class="badge" style="background-color: #5e9299;">Médecin</span>
                    {% else %}
                        <span class="badge" style="background-color: #07232c;">Patient</span>
                    {% endif %}
                </td>
                <td>
                    {% if user.active %}
                        <span class="badge" style="background-color: #73b47e;">Actif</span>
                    {% else %}
                        <span class="badge" style="background-color: #ce4848;">Inactif</span>
                    {% endif %}
                </td>
                <td>{{ user.createdAt ? user.createdAt|date('d/m/Y') : '-' }}</td>
                <td>
                    <form method="post" action="{{ path('admin_user_toggle', {id: user.id}) }}" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                        <button type="submit" class="btn btn-sm {% if user.active %}btn-outline-danger{% else %}btn-outline-primary{% endif %}">
                            {% if user.active %}
                                <i class="bi bi-pause-circle"></i> Désactiver
                            {% else %}
                                <i class="bi bi-play-circle"></i> Activer
                            {% endif %}
                        </button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('admin_dashboard') }}" class="button mt-2" style="color: #07232c; text-decoration: none;">
        <i class="bi bi-arrow-left"></i> Retour au dashboard
    </a>
</div>
{% endblock %}