{% extends 'base.html.twig' %}

{% block title %}Demandes médecins - Health North{% endblock %}

{% block body %}
<style>

      
        .button {
        font-size: 1rem;
        border: 1.5px solid #ffffff ;
        background-color: white;
        border-radius: 0.5rem;
        box-shadow: 2.5px 3px 0 #082833;
        outline: none;
        transition: ease 0.25s;
        font-weight: 600;
        white-space: nowrap;
        padding: 3px 6px;
    }

     .button:hover {
        box-shadow: 5.5px 7px 0 #082833;
        transform: translateY(-2px);
     }

      
</style>


<div class="container mt-4">
    <h2> Demandes d'inscription médecins</h2>
    <hr>

    {% if medecins|length == 0 %}
        <div>
            <i class="bi bi-check-circle"></i> Aucune demande en attente.
        </div>
    {% else %}
        {% for medecin in medecins %}
        <div class="card shadow-sm mb-3" style="border-color: #072935; box-sizing: 2px;">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h5>Dr. {{ medecin.nom }} {{ medecin.prenom }}</h5>
                        <p class="text-muted mb-1">
                            <i class="bi bi-briefcase"></i> {{ medecin.specialite }} &nbsp;|&nbsp;
                            <i class="bi bi-geo-alt"></i> {{ medecin.ville }} &nbsp;|&nbsp;
                            <i class="bi bi-hash"></i> RPPS : {{ medecin.numeroRPPS }}
                        </p>
                        <p class="text-muted mb-0">
                            <i class="bi bi-envelope"></i> {{ medecin.user.email }} &nbsp;|&nbsp;
                            <i class="bi bi-telephone"></i> {{ medecin.telephone }}
                        </p>
                    </div>
                    <div class="col-md-4 text-end">
                        <form method="post" action="{{ path('admin_medecin_valider', {id: medecin.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('valider' ~ medecin.id) }}">
                            <button type="submit" class="btn btn-outline-success btn-sm">
                                <i class="bi bi-check-lg"></i> Valider
                            </button>
                        </form>
                        <form method="post" action="{{ path('admin_medecin_refuser', {id: medecin.id}) }}" class="d-inline ms-2">
                            <input type="hidden" name="_token" value="{{ csrf_token('refuser' ~ medecin.id) }}">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-x-lg"></i> Refuser
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    {% endif %}

    <a href="{{ path('admin_dashboard') }}" class="button mt-2" style="text-decoration:none; color: #082833;">
        <i class="bi bi-arrow-left"></i> Retour au dashboard
    </a>
</div>
{% endblock %}