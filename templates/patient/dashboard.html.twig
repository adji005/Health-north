{% extends 'base.html.twig' %}

{% block title %}Mon espace - Health North{% endblock %}

{% block body %}

<style>
    body {
        font-family: 'Inter';
    }

    .list-group-item.active{
        background-color: #072935;

    }


</style> 

<div class="mb-5 pb-5"></div>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="card shadow-sm" style="border-color: #072935; box-sizing: 2px;">
                <div class="card-body text-center p-4" >
                    <i class="bi bi-person fs-1 "></i>
                    <h5 class="mt-2">{{ patient.prenom }} {{ patient.nom }}</h5>
                    <p class="text-muted small">{{ app.user.email }}</p>
                </div>
                <div class="list-group list-group-flush" style="border-color: #072935; box-sizing: 2px;">
                    <a href="{{ path('patient_dashboard') }}" class="list-group-item list-group-item-action active" style="border-color: #072935; box-sizing: 2px;">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                    <a href="{{ path('patient_rdv') }}" class="list-group-item list-group-item-action" style="border-color: #072935; box-sizing: 2px;">
                        <i class="bi bi-calendar-check"></i> Mes rendez-vous
                    </a>
                    <a href="{{ path('patient_dossier') }}" class="list-group-item list-group-item-action" style="border-color: #072935; box-sizing: 2px;">
                        <i class="bi bi-file-medical"></i> Mon dossier
                    </a>
                    <a href="{{ path('search') }}" class="list-group-item list-group-item-action">
                        <i class="bi bi-search"></i> Trouver un médecin
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <h3>Bonjour {{ patient.prenom }} !</h3>
            <hr>

            <h5 class="mb-3">Mes prochains rendez-vous</h5>
            
            {% if rendezVous|length == 0 %}
                <p>Aucun rendez-vous à venir. <a href="{{ path('search') }}" style="color: #072935; font-weight: 600; text-decoration: none;">Prendre un rendez-vous</a></p>
            {% else %}
                {% for rdv in rendezVous %}
                    <div class="card shadow-sm mb-3" style="border-color: #072935;">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <h6>Dr. {{ rdv.medecin.nom }} {{ rdv.medecin.prenom }}</h6>
                                    <p class="text-muted mb-1">
                                        <i class="bi bi-calendar"></i> {{ rdv.dateHeure|date('d/m/Y à H:i') }}
                                    </p>
                                </div>
                                <div class="col-md-4 text-end">
                                    <span class="badge" style="background-color: #072935;">Confirmé</span>
                                    <form method="post" action="{{ path('patient_rdv_annuler', {id: rdv.id}) }}" class="d-inline ms-2">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            Annuler
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</div>

<div class="mb-5 pb-5"></div>
<div class="mb-5 pb-5"></div>


{% endblock %}