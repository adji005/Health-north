{% extends 'base.html.twig' %}

{% block title %}Mon espace - Health North{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body text-center p-4">
                    <i class="bi bi-person-circle fs-1 text-primary"></i>
                    <h5 class="mt-2">{{ patient.prenom }} {{ patient.nom }}</h5>
                    <p class="text-muted small">{{ app.user.email }}</p>
                </div>
                <div class="list-group list-group-flush">
                    <a href="{{ path('patient_dashboard') }}" class="list-group-item list-group-item-action active">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                    <a href="{{ path('patient_rdv') }}" class="list-group-item list-group-item-action">
                        <i class="bi bi-calendar-check"></i> Mes rendez-vous
                    </a>
                    <a href="{{ path('patient_dossier') }}" class="list-group-item list-group-item-action">
                        <i class="bi bi-file-medical"></i> Mon dossier
                    </a>
                    <a href="{{ path('search') }}" class="list-group-item list-group-item-action">
                        <i class="bi bi-search"></i> Trouver un médecin
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <h3>Bonjour {{ patient.prenom }} </h3>
            <hr>

            <h5 class="mb-3">Mes prochains rendez-vous</h5>
            {% set hasUpcoming = false %}
            {% for rdv in rendezVous %}
                {% if rdv.statut == 'confirme' %}
                    {% set hasUpcoming = true %}
                    <div class="card shadow-sm mb-3">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <h6>Dr. {{ rdv.medecin.nom }} {{ rdv.medecin.prenom }}</h6>
                                    <p class="text-muted mb-1">
                                        <i class="bi bi-calendar"></i> {{ rdv.dateHeure|date('d/m/Y à H:i') }}
                                    </p>
                                
                                </div>
                                <div class="col-md-4 text-end">
                                    <span class="badge bg-success">Confirmé</span>
                                    <form method="post" action="{{ path('patient_rdv_annuler', {id: rdv.id}) }}" class="d-inline ms-2">
                                        <button type="submit" class="btn btn-outline-danger btn-sm"
                                            onclick="return confirm('Annuler ce rendez-vous ?')">
                                            Annuler
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}

            {% if not hasUpcoming %}
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Aucun rendez-vous à venir.
                    <a href="{{ path('search') }}" class="alert-link">Prendre un rendez-vous</a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}