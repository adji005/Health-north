{% extends 'base.html.twig' %}

{% block title %}Mes rendez-vous - Health North{% endblock %}

{% block body %}

<style>
    body {
        font-family: 'Inter';
    }

    .list-group-item.active {
        background-color: #072935;
    }
</style> 

<div class="mb-5 pb-5"></div>


<div class="container mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="card shadow-sm" style="border-color: #072935;">
                <div class="card-body text-center p-4">
                    <i class="bi bi-person-circle fs-1"></i>
                    <h5 class="mt-2">{{ patient.prenom }} {{ patient.nom }}</h5>
                    <p class="text-muted small">{{ app.user.email }}</p>
                </div>
                <div class="list-group list-group-flush">
                    <a href="{{ path('patient_dashboard') }}" class="list-group-item list-group-item-action">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                    <a href="{{ path('patient_rdv') }}" class="list-group-item list-group-item-action active">
                        <i class="bi bi-calendar-check"></i> Mes rendez-vous
                    </a>
                    <a href="{{ path('patient_dossier') }}" class="list-group-item list-group-item-action">
                        <i class="bi bi-file-medical"></i> Mon dossier
                    </a>
                    <a href="{{ path('search') }}" class="list-group-item list-group-item-action">
                        <i class="bi bi-search"></i> Trouver un médecin
                    </a>
                </div>
            </div>
        </div>

        <!--affichage des rdv-->

        <div class="col-md-9">
            <h3>Mes rendez-vous</h3>
            <hr>

            {% if rendezVous|length == 0 %}
                <p>Aucun rendez-vous. <a href="{{ path('search') }}" class="alert-link" style="font-weight: 600; font-family: Inter; text-decoration: none;">Prendre un rendez-vous</a></p> 
            {% else %}
                {% for rdv in rendezVous %}
                <div class="card shadow-sm mb-3" style="border-color: #072935;">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h6>Dr. {{ rdv.medecin.nom }} {{ rdv.medecin.prenom }}</h6>
                                <p class="text-muted mb-1">
                                    <i class="bi bi-calendar"></i> {{ rdv.dateHeure|date('d/m/Y à H:i') }}
                                </p>
                               
                                {% if rdv.motif %}
                                    <p class="text-muted mb-0">
                                        <i class="bi bi-chat-text"></i> {{ rdv.motif }}
                                    </p>
                                {% endif %}

                                {% if rdv.statut == 'termine' and rdv.consultation %}
                                    <div class="mt-2 mb-0">
                                        <strong><i class="bi bi-file-text"></i> Notes du médecin :</strong><br>
                                        {{ rdv.consultation.notes }}
                                    </div>
                                {% endif %}
                            </div>

                            <!--annnuler un rdv-->
                            <div class="col-md-4 text-end">
                                {% if rdv.statut == 'confirme' %}
                                    <span class="badge" style="background-color: #012741;">Confirmé</span>
                                    <br>
                                    <form method="post" action="{{ path('patient_rdv_annuler', {id: rdv.id}) }}">
                                        <button type="submit" class="btn btn-outline-danger btn-sm" style="padding: 2px; margin-top: 10px;">
                                            <i class="bi bi-x-circle"></i> Annuler
                                        </button>
                                    </form>
                                {% elseif rdv.statut == 'annule' %}
                                    <span class="badge" style="background-color: #326079;">Annulé</span>
                                {% elseif rdv.statut == 'termine' %}
                                    <span class="badge" style="background-color: #034C3C;">Terminé</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</div>

<div class="mb-5 pb-5"></div>
<div class="mb-5 pb-5"></div>

{% endblock %}